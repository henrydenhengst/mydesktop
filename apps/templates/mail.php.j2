<?php
// Gegevens uit Ansible variabelen
$to = "{{ site_author_email }}";
$subject = "Nieuw bericht van {{ site_title }}";

if ($_SERVER["REQUEST_METHOD"] == "POST") {
    $name = strip_tags(trim($_POST["name"]));
    $email = filter_var(trim($_POST["email"]), FILTER_SANITIZE_EMAIL);
    $message = trim($_POST["message"]);

    if (empty($name) || !filter_var($email, FILTER_VALIDATE_EMAIL) || empty($message)) {
        http_response_code(400);
        echo "Vul a.u.b. alle velden correct in.";
        exit;
    }

    $email_content = "Naam: $name\n";
    $email_content .= "Email: $email\n\n";
    $email_content .= "Bericht:\n$message\n";

    $headers = "From: $name <$email>";

    if (mail($to, $subject, $email_content, $headers)) {
        http_response_code(200);
        echo "Bedankt! Je bericht is verzonden.";
    } else {
        http_response_code(500);
        echo "Oeps! Er ging iets mis.";
    }
} else {
    http_response_code(403);
    echo "Er is een probleem met je verzending.";
}
?>
